[
  {
    "name": "SheetsRead",
    "description": "Read values from a Google Sheets spreadsheet by range (e.g. 'Sheet1!A1:C10')",
    "inputSchema": {
      "type": "object",
      "properties": {
        "spreadsheetId": {
          "type": "string",
          "description": "The spreadsheet ID (from the URL)"
        },
        "range": {
          "type": "string",
          "description": "A1 notation range, e.g. 'Sheet1!A1:C10'"
        }
      },
      "required": ["spreadsheetId", "range"]
    }
  },
  {
    "name": "SheetsWrite",
    "description": "Write or append values to a Google Sheets spreadsheet",
    "inputSchema": {
      "type": "object",
      "properties": {
        "spreadsheetId": {
          "type": "string",
          "description": "The spreadsheet ID"
        },
        "range": {
          "type": "string",
          "description": "A1 notation range for where to write"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {}
          },
          "description": "2D array of values to write"
        },
        "append": {
          "type": "boolean",
          "description": "If true, append rows after existing data",
          "default": false
        }
      },
      "required": ["spreadsheetId", "range", "values"]
    }
  },
  {
    "name": "SheetsCreate",
    "description": "Create a new Google Sheets spreadsheet",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title for the new spreadsheet"
        },
        "sheetNames": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional list of sheet/tab names to create"
        }
      },
      "required": ["title"]
    }
  },
  {
    "name": "CalendarList",
    "description": "List upcoming events from Google Calendar",
    "inputSchema": {
      "type": "object",
      "properties": {
        "calendarId": {
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "default": "primary"
        },
        "query": {
          "type": "string",
          "description": "Free-text search query to filter events"
        },
        "timeMin": {
          "type": "string",
          "description": "Start of time range (ISO 8601). Defaults to now."
        },
        "timeMax": {
          "type": "string",
          "description": "End of time range (ISO 8601)"
        },
        "maxResults": {
          "type": "number",
          "description": "Max events to return (default: 10)",
          "default": 10
        }
      }
    }
  },
  {
    "name": "CalendarCreate",
    "description": "Create a new Google Calendar event",
    "inputSchema": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Event title"
        },
        "start": {
          "type": "string",
          "description": "Start time (ISO 8601)"
        },
        "end": {
          "type": "string",
          "description": "End time (ISO 8601)"
        },
        "description": {
          "type": "string",
          "description": "Event description"
        },
        "location": {
          "type": "string",
          "description": "Event location"
        },
        "attendees": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Attendee email addresses"
        },
        "calendarId": {
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "default": "primary"
        }
      },
      "required": ["summary", "start", "end"]
    }
  },
  {
    "name": "CalendarUpdate",
    "description": "Update or delete a Google Calendar event",
    "inputSchema": {
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string",
          "description": "The event ID to update or delete"
        },
        "calendarId": {
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "default": "primary"
        },
        "delete": {
          "type": "boolean",
          "description": "Set true to delete the event",
          "default": false
        },
        "summary": {
          "type": "string",
          "description": "New event title"
        },
        "start": {
          "type": "string",
          "description": "New start time (ISO 8601)"
        },
        "end": {
          "type": "string",
          "description": "New end time (ISO 8601)"
        },
        "description": {
          "type": "string",
          "description": "New event description"
        },
        "location": {
          "type": "string",
          "description": "New event location"
        },
        "attendees": {
          "type": "array",
          "items": { "type": "string" },
          "description": "New attendee emails (replaces existing)"
        }
      },
      "required": ["eventId"]
    }
  },
  {
    "name": "DocsRead",
    "description": "Read a Google Doc's content as plain text",
    "inputSchema": {
      "type": "object",
      "properties": {
        "documentId": {
          "type": "string",
          "description": "The Google Doc ID (from the URL)"
        }
      },
      "required": ["documentId"]
    }
  },
  {
    "name": "DocsCreate",
    "description": "Create a new Google Doc with optional initial content",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title for the new document"
        },
        "content": {
          "type": "string",
          "description": "Optional initial text content (supports **bold** and *italic*)"
        }
      },
      "required": ["title"]
    }
  },
  {
    "name": "DocsUpdate",
    "description": "Update an existing Google Doc (append, find-and-replace, or insert at position)",
    "inputSchema": {
      "type": "object",
      "properties": {
        "documentId": {
          "type": "string",
          "description": "The Google Doc ID to update"
        },
        "appendText": {
          "type": "string",
          "description": "Text to append at end of document (supports **bold** and *italic*)"
        },
        "replaceText": {
          "type": "string",
          "description": "Text to find in the document"
        },
        "replacementText": {
          "type": "string",
          "description": "Text to replace it with"
        },
        "insertText": {
          "type": "string",
          "description": "Text to insert at a specific position (supports **bold** and *italic*)"
        },
        "insertIndex": {
          "type": "number",
          "description": "Character index where to insert (1-based)"
        }
      },
      "required": ["documentId"]
    }
  },
  {
    "name": "SlidesRead",
    "description": "Read a Google Slides presentation including text, images, tables, backgrounds, and speaker notes",
    "inputSchema": {
      "type": "object",
      "properties": {
        "presentationId": {
          "type": "string",
          "description": "The presentation ID (from the URL)"
        }
      },
      "required": ["presentationId"]
    }
  },
  {
    "name": "SlidesCreate",
    "description": "Create a Google Slides presentation with slides supporting text, backgrounds, images, and speaker notes",
    "inputSchema": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title for the new presentation"
        },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Slide title"
              },
              "body": {
                "type": "string",
                "description": "Slide body text"
              },
              "layout": {
                "type": "string",
                "description": "Layout: TITLE_AND_BODY, TITLE_ONLY, BLANK, etc. Auto-detected if omitted."
              },
              "backgroundColor": {
                "type": "string",
                "description": "Background color as hex (e.g. '#1a1a2e')"
              },
              "backgroundImageUrl": {
                "type": "string",
                "description": "URL for background image (stretched to fill)"
              },
              "imageUrl": {
                "type": "string",
                "description": "URL of image to place on the slide"
              },
              "imageX": {
                "type": "number",
                "description": "Image X position as % of slide width (0-100, default 10)"
              },
              "imageY": {
                "type": "number",
                "description": "Image Y position as % of slide height (0-100, default 10)"
              },
              "imageWidth": {
                "type": "number",
                "description": "Image width as % of slide width (0-100, default 80)"
              },
              "imageHeight": {
                "type": "number",
                "description": "Image height as % of slide height (0-100, default 80)"
              },
              "notes": {
                "type": "string",
                "description": "Speaker notes for this slide"
              }
            }
          },
          "description": "Array of slides with text, layout, backgrounds, images, and notes"
        }
      },
      "required": ["title"]
    }
  },
  {
    "name": "SlidesUpdate",
    "description": "Update a Google Slides presentation: add/delete slides, insert images, set backgrounds, add shapes/tables, style text",
    "inputSchema": {
      "type": "object",
      "properties": {
        "presentationId": {
          "type": "string",
          "description": "The presentation ID to update"
        },
        "addSlide": {
          "type": "object",
          "properties": {
            "title": { "type": "string", "description": "Slide title" },
            "body": { "type": "string", "description": "Slide body text" },
            "layout": { "type": "string", "description": "Layout (auto-detected if omitted)" },
            "backgroundColor": { "type": "string", "description": "Background hex color" },
            "backgroundImageUrl": { "type": "string", "description": "Background image URL" },
            "imageUrl": { "type": "string", "description": "Image URL to place on slide" },
            "imageX": { "type": "number" },
            "imageY": { "type": "number" },
            "imageWidth": { "type": "number" },
            "imageHeight": { "type": "number" },
            "notes": { "type": "string", "description": "Speaker notes" }
          },
          "description": "Add a new slide at the end"
        },
        "replaceText": {
          "type": "string",
          "description": "Text to find across all slides"
        },
        "replacementText": {
          "type": "string",
          "description": "Text to replace it with"
        },
        "deleteSlideIndex": {
          "type": "number",
          "description": "0-based index of the slide to delete"
        },
        "insertImage": {
          "type": "object",
          "properties": {
            "slideIndex": { "type": "number", "description": "0-based slide index" },
            "imageUrl": { "type": "string", "description": "Image URL" },
            "x": { "type": "number", "description": "X position as % (0-100, default 10)" },
            "y": { "type": "number", "description": "Y position as % (0-100, default 10)" },
            "width": { "type": "number", "description": "Width as % (0-100, default 80)" },
            "height": { "type": "number", "description": "Height as % (0-100, default 80)" }
          },
          "required": ["slideIndex", "imageUrl"],
          "description": "Insert an image on an existing slide"
        },
        "setBackground": {
          "type": "object",
          "properties": {
            "slideIndex": { "type": "number", "description": "0-based slide index" },
            "color": { "type": "string", "description": "Hex color (e.g. '#1a1a2e')" },
            "imageUrl": { "type": "string", "description": "Image URL for background" }
          },
          "required": ["slideIndex"],
          "description": "Set slide background color or image"
        },
        "addShape": {
          "type": "object",
          "properties": {
            "slideIndex": { "type": "number", "description": "0-based slide index" },
            "shapeType": { "type": "string", "description": "RECTANGLE, TEXT_BOX, ELLIPSE, etc. (default RECTANGLE)" },
            "x": { "type": "number", "description": "X position as % (0-100)" },
            "y": { "type": "number", "description": "Y position as % (0-100)" },
            "width": { "type": "number", "description": "Width as % (0-100)" },
            "height": { "type": "number", "description": "Height as % (0-100)" },
            "fillColor": { "type": "string", "description": "Fill hex color" },
            "borderColor": { "type": "string", "description": "Border hex color" },
            "text": { "type": "string", "description": "Text inside the shape" }
          },
          "required": ["slideIndex", "x", "y", "width", "height"],
          "description": "Add a shape to a slide"
        },
        "addTable": {
          "type": "object",
          "properties": {
            "slideIndex": { "type": "number", "description": "0-based slide index" },
            "rows": { "type": "number", "description": "Number of rows" },
            "columns": { "type": "number", "description": "Number of columns" },
            "data": {
              "type": "array",
              "items": { "type": "array", "items": { "type": "string" } },
              "description": "2D array of cell text"
            },
            "x": { "type": "number", "description": "X position as % (0-100)" },
            "y": { "type": "number", "description": "Y position as % (0-100)" },
            "width": { "type": "number", "description": "Width as % (0-100)" },
            "height": { "type": "number", "description": "Height as % (0-100)" }
          },
          "required": ["slideIndex", "rows", "columns"],
          "description": "Add a table to a slide"
        },
        "updateTextStyle": {
          "type": "object",
          "properties": {
            "slideIndex": { "type": "number", "description": "0-based slide index" },
            "bold": { "type": "boolean" },
            "italic": { "type": "boolean" },
            "underline": { "type": "boolean" },
            "fontFamily": { "type": "string", "description": "Font name (e.g. 'Arial')" },
            "fontSize": { "type": "number", "description": "Font size in points" },
            "color": { "type": "string", "description": "Text color as hex" }
          },
          "required": ["slideIndex"],
          "description": "Style all text on a slide"
        }
      },
      "required": ["presentationId"]
    }
  },
  {
    "name": "DriveList",
    "description": "List files in Google Drive with optional filtering",
    "inputSchema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Drive search query (e.g. \"name contains 'report'\")"
        },
        "folderId": {
          "type": "string",
          "description": "Folder ID to list contents of"
        },
        "mimeType": {
          "type": "string",
          "description": "Filter by MIME type"
        },
        "maxResults": {
          "type": "number",
          "description": "Max files to return (default: 20)",
          "default": 20
        }
      }
    }
  },
  {
    "name": "DriveDownload",
    "description": "Download or export a file from Google Drive",
    "inputSchema": {
      "type": "object",
      "properties": {
        "fileId": {
          "type": "string",
          "description": "The file ID to download"
        },
        "outputPath": {
          "type": "string",
          "description": "Local path to save the file"
        },
        "exportMimeType": {
          "type": "string",
          "description": "MIME type to export Google Docs/Sheets/Slides to (e.g. 'text/plain', 'application/pdf', 'text/csv')"
        }
      },
      "required": ["fileId", "outputPath"]
    }
  }
]
